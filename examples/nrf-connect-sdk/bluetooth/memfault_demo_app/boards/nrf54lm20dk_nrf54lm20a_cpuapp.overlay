/* Reserve a fixed retained SRAM window for Memfault reboot tracking and
 * RAM-backed coredumps without shifting the main RAM placement.
 */

/ {
	memfault_noinit_sram: memfault_noinit_sram@2007f000 {
		compatible = "zephyr,memory-region", "mmio-sram";
		reg = <0x2007f000 0xc00>;
		zephyr,memory-region = "MemfaultNoInit";
		status = "okay";
	};
};

&cpuapp_sram {
	reg = <0x20000000 0x7f000>;
	ranges = <0x0 0x20000000 0x7f000>;
};
